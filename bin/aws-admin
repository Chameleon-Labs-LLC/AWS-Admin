#!/usr/bin/env bash
# Self-healing launcher for the aws-admin CLI.
#
# Ensures .venv_linux exists and matches pyproject.toml, then execs the real
# CLI with all arguments. The editable install (`pip install -e .`) picks up
# src/ changes automatically, so a reinstall happens ONLY when:
#   - the venv (or its aws-admin entry point) is missing, or
#   - pyproject.toml changed since the last install (deps/entry points).
#
# Slash commands and humans should call THIS script instead of
# .venv_linux/bin/aws-admin directly — it never fails just because the venv
# was wiped, and it never reinstalls when nothing changed.
set -euo pipefail

REPO="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
VENV="$REPO/.venv_linux"
BIN="$VENV/bin/aws-admin"
STAMP="$VENV/.pyproject.stamp"   # byte-for-byte copy of pyproject.toml at install time

needs_install=0
if [[ ! -x "$BIN" ]]; then
  needs_install=1
elif ! cmp -s "$REPO/pyproject.toml" "$STAMP"; then
  needs_install=1
fi

if [[ "$needs_install" -eq 1 ]]; then
  echo "[aws-admin] venv missing or pyproject.toml changed — (re)installing into $VENV ..." >&2
  [[ -d "$VENV" ]] || python3 -m venv "$VENV"
  "$VENV/bin/pip" install -q -e "$REPO"
  cp "$REPO/pyproject.toml" "$STAMP"
fi

exec "$BIN" "$@"
